{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "types": ["node"],
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "allowJs": false,
    "jsx": "react-jsx"
  },
  "include": ["src/**/*.ts"]
}
